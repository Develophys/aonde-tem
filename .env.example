# --- Database (PostGIS) ---
DATABASE_URL=postgresql://aonde:aonde@localhost:5432/aonde

# --- API ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# --- Geocoding provider (LocationIQ free tier; Nominatim-compatible) ---
GEOCODING_BASE_URL=https://us1.locationiq.com/v1
GEOCODING_API_KEY=replace-me

# --- Web (Vite needs the VITE_ prefix to expose to the client) ---
VITE_API_URL=http://localhost:3000
VITE_MAP_KEY=replace-with-maptiler-key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
