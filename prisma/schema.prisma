generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Place {
  id       String  @id @default(uuid())
  name     String
  category String
  address  String?
  // PostGIS has no native Prisma type — modelled as Unsupported and queried via $queryRaw.
  location Unsupported("geography(Point, 4326)")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("places")
}
